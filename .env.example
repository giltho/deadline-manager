# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=123456789012345678

# Channel where deadline slash commands are accepted
DEADLINE_CHANNEL_ID=123456789012345678

# Channel where reminder messages are broadcast
REMINDER_CHANNEL_ID=123456789012345678

# REST API — Raycast extension OAuth2
# Reuse the same Discord application as the bot (OAuth2 → Client ID / Secret).
# In the Discord Developer Portal (OAuth2 → Redirects), add exactly:
#   https://raycast.com/redirect?packageName=Extension
# This is the redirect URI used by the Raycast extension direct PKCE flow.
# Do NOT use oauth.raycast.com proxy URLs — Discord supports PKCE natively.
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret

# Public hostname for the FastAPI server (used by Traefik routing in docker-compose).
# Do not include https:// or a trailing slash.
DEADLINE_HOSTNAME=deadlines.example.com

# Port the FastAPI server listens on inside the container (default: 8000).
# Traefik routes external HTTPS (443) to this port — do not expose it directly.
# API_PORT=8000

# Microsoft Graph API (optional — omit all MS_* vars to disable calendar sync)
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_CALENDAR_ID=your-shared-mailbox@example.com

