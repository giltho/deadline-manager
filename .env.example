# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=123456789012345678

# Channel where deadline slash commands are accepted
DEADLINE_CHANNEL_ID=123456789012345678

# Channel where reminder messages are broadcast
REMINDER_CHANNEL_ID=123456789012345678

# REST API — Raycast extension OAuth2
# Reuse the same Discord application as the bot (OAuth2 → Client ID / Secret).
# Add https://raycast.com/redirect?packageName=Extension as a redirect URI.
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_CLIENT_SECRET=your-discord-application-client-secret

# Port the FastAPI server listens on (default: 8000)
# API_PORT=8000

# Microsoft Graph API (optional — omit all MS_* vars to disable calendar sync)
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_CALENDAR_ID=your-shared-mailbox@example.com
