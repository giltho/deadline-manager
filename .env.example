# Discord
DISCORD_TOKEN=your-discord-bot-token
DISCORD_GUILD_ID=123456789012345678

# Comma-separated role IDs allowed to manage deadlines
ALLOWED_ROLE_IDS=123456789,987654321

# Channel where reminder messages are broadcast
REMINDER_CHANNEL_ID=123456789012345678

# Microsoft Graph API (optional — omit all MS_* vars to disable calendar sync)
# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=
# MS_CALENDAR_ID=your-shared-mailbox@example.com
